datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Patient {
  id        String   @id
  name      String
  room      String
  deviceId  String   @unique
  illness   String?
  condition String?
  createdAt DateTime @default(now())
}
